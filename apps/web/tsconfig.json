{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@open-design/artifacts": ["packages/artifacts/src/index.ts"],
      "@open-design/components": ["packages/components/src/index.tsx"],
      "@open-design/contracts": ["packages/contracts/src/index.ts"],
      "@open-design/model-registry": ["packages/model-registry/src/index.ts"],
      "@open-design/prompts": ["packages/prompts/src/index.ts"],
      "@/*": ["apps/web/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
